<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/theme_background">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="AutoSilent"
                    android:textColor="@color/theme_text_primary"
                    android:textSize="28sp"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="-0.02"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground" />

                <ImageButton
                    android:id="@+id/btnCheckUpdate"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@android:drawable/stat_sys_download"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="@color/ios_blue"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="@string/check_updates" />

                <!-- Compact Segmented Toggle in Top Right -->
                <LinearLayout
                    android:id="@+id/toggleAppearance"
                    android:layout_width="80dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_segmented_track"
                    android:orientation="horizontal"
                    android:padding="2dp">

                    <TextView
                        android:id="@+id/tvModeLight"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="☀️"
                        android:textSize="14sp"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/tvModeDark"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="🌙"
                        android:textSize="14sp"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>
            </LinearLayout>

            <!-- Status Bar / Current Mode -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/theme_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/ivCurrentModeIcon"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_lock_silent_mode"
                        app:tint="@color/ios_blue"
                        android:layout_marginEnd="12dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Current Mode"
                            android:textColor="@color/theme_text_secondary"
                            android:textSize="12sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.05" />
                        <TextView
                            android:id="@+id/tvCurrentMode"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Normal"
                            android:textColor="@color/theme_text_primary"
                            android:textSize="18sp"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvQuickSilenceTimer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Timer: --:--"
                        android:textColor="@color/ios_red"
                        android:textSize="14sp"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Main Settings Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/theme_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Enable Scheduling"
                        android:textColor="@color/theme_text_primary"
                        android:textSize="17sp"
                        android:fontFamily="sans-serif-medium" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchEnabled"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- JNTUA Professional Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardJntua"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/theme_surface">

                <LinearLayout
                    android:id="@+id/layoutJntuaInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical"
                    android:background="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="JNTUA Schedule"
                            android:textColor="@color/theme_text_primary"
                            android:textSize="17sp"
                            android:fontFamily="sans-serif-medium" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="College timings • Toggled together"
                            android:textColor="@color/theme_text_secondary"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchJntua"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="YOUR SCHEDULES"
                android:textColor="@color/theme_text_secondary"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.05"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="8dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvSchedules"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_schedule" />

            <!-- Permissions Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                android:layout_marginTop="24dp"
                app:cardBackgroundColor="@color/theme_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="12dp"
                        android:gravity="center_vertical">
                        <ImageView
                            android:id="@+id/ivDndDot"
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:src="@android:drawable/presence_online"
                            android:layout_marginEnd="12dp"/>
                        <TextView
                            android:id="@+id/tvDndStatus"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="DND Access"
                            android:textColor="@color/theme_text_primary"
                            android:textSize="15sp" />
                        <Button
                            android:id="@+id/btnGrantDnd"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Allow"
                            android:textSize="13sp"
                            android:textColor="@color/ios_blue"
                            android:visibility="gone"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/theme_divider" android:layout_marginHorizontal="16dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="12dp"
                        android:gravity="center_vertical">
                        <ImageView
                            android:id="@+id/ivBatteryDot"
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:src="@android:drawable/presence_online"
                            android:layout_marginEnd="12dp"/>
                        <TextView
                            android:id="@+id/tvBatteryStatus"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Battery Usage"
                            android:textColor="@color/theme_text_primary"
                            android:textSize="15sp" />
                        <Button
                            android:id="@+id/btnGrantBattery"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Allow"
                            android:textSize="13sp"
                            android:textColor="@color/ios_blue"
                            android:visibility="gone"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <View android:layout_width="match_parent" android:layout_height="100dp"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAdd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        app:srcCompat="@android:drawable/ic_input_add"
        app:tint="@android:color/white"
        app:backgroundTint="@color/ios_blue"
        app:elevation="4dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnReportIssue"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_margin="16dp"
        android:text="@string/report_issue"
        android:textColor="@color/theme_text_secondary"
        android:textSize="12sp"
        android:textAllCaps="false"
        app:rippleColor="@color/ios_red" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
